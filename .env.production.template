# ======================================
# KBM 2.0 Production Environment Template
# ======================================
# Copy this file to `.env` on your VPS and fill in the marked values.
# `deploy/install_vps.sh` will do this automatically on first run.
# NEVER commit the resulting .env file to git.

# Environment
ENV=production
FLASK_ENV=production
PYTHONUNBUFFERED=1

# --- REQUIRED: rotate per deployment ---
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=__GENERATE_ME__

# Shared secret used by Caddy to authenticate against the app's
# /_internal/check-domain endpoint. Generate with the same command above.
INTERNAL_API_SECRET=__GENERATE_ME__

# --- REQUIRED: domain config ---
# The bare apex domain — no scheme, no port, no leading dot.
# Tenant subdomains will be served as <subdomain>.${BASE_DOMAIN}.
BASE_DOMAIN=buywithvesta.com
SERVER_NAME=buywithvesta.com

# Email registered with Let's Encrypt for cert expiry notices.
ACME_EMAIL=admin@buywithvesta.com

# --- REQUIRED: host docker group GID ---
# Detected by install_vps.sh via: getent group docker | cut -d: -f3
# Used by compose.yaml `group_add` so the container can use the host docker socket.
DOCKER_GID=999

# --- App settings ---
# Multi-tenant mode does not use a single DATABASE_URI. Each tenant has its own
# SQLite file under tenant_dbs/. Master DB is at master_db/master.db.
AUTO_CREATE_SCHEMA=false
PORT=8000

# Gunicorn
WORKERS=4
TIMEOUT=120
LOG_LEVEL=info

# Sessions
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=3600

# Uploads (16 MiB)
MAX_CONTENT_LENGTH=16777216

# Rate limiting
RATELIMIT_ENABLED=true
RATELIMIT_STORAGE_URL=memory://
