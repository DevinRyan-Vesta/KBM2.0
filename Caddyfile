{
	# Email used for Let's Encrypt registration / cert expiry notices.
	email {$ACME_EMAIL}

	# On-demand TLS lets Caddy issue a cert for any subdomain on first hit,
	# but only if the ask endpoint returns 200. The endpoint verifies the
	# subdomain belongs to a real, active tenant in the master DB.
	on_demand_tls {
		ask http://python-app:8000/_internal/check-domain?secret={$INTERNAL_API_SECRET}
	}
}

# Root domain + explicit www subdomain. Cert is provisioned eagerly at startup.
{$BASE_DOMAIN}, www.{$BASE_DOMAIN} {
	encode zstd gzip
	reverse_proxy python-app:8000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Wildcard catch-all for tenant subdomains. Certs are issued on-demand,
# gated by the ask endpoint above.
*.{$BASE_DOMAIN} {
	tls {
		on_demand
	}
	encode zstd gzip
	reverse_proxy python-app:8000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
